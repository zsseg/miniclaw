            else:
                payload["temperature"] = 0.2
        else:
            temperature = 0.1
            if has_image_refs:
                temperature = 0.2
            if tone:
                temperature = 0.3
            payload["temperature"] = temperature

        data = json.dumps(payload, ensure_ascii=False).encode("utf-8")

        req = urllib.request.Request(
            endpoint,
            data=data,
            headers={
                "Authorization": f"Bearer {api_key}",
                "Content-Type": "application/json",
            },
            method="POST",
