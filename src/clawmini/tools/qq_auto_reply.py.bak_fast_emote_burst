                    else:
                        role = f"{speaker}(ID={item_sender or '未知'})"

                    lines.append(f"- {role}: {line_text}")
        if image_refs:
            lines.append("图片线索：")
            for ref in image_refs[:3]:  # 从 5 张减少到 3 张
