    def _strip_cq_for_social_gate(self, text: str) -> str:
        clean = str(text or "")
        clean = re.sub(r"\[CQ:at,[^\]]+\]", "", clean)
        clean = re.sub(r"\[CQ:(face|image|forward)[^\]]+\]", "", clean)
        clean = re.sub(r"\s+", " ", clean).strip()
        return clean

